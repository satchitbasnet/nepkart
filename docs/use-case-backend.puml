@startuml NEPKART-Backend-UseCases
' Landscape format for presentations - export as PNG/SVG at plantuml.com
!theme plain
skinparam actorStyle awesome
skinparam useCase {
  BackgroundColor LightGreen
  BorderColor DarkGreen
}
skinparam pagesize 1600x900
skinparam defaultFontSize 11
' Force landscape: width > height, left-to-right layout
left to right direction

actor "Customer" as Customer
actor "Admin" as Admin

rectangle "NEPKART Backend (Spring Boot API)" {
  ' Customer
  usecase "Auth: Register, Login, Logout" as B1
  usecase "Products: List, Get" as B2
  usecase "Cart: Get, Sync" as B3
  usecase "Orders: Create" as B4
  usecase "Shipping & Tax" as B5
  ' Admin
  usecase "Admin Login" as B6
  usecase "Products: CRUD" as B7
  usecase "Orders: List, Update Status" as B8
  usecase "Customers: List, Set Active" as B9
}

Customer --> B1
Customer --> B2
Customer --> B3
Customer --> B4
Customer --> B5

Admin --> B6
Admin --> B7
Admin --> B8
Admin --> B9
@enduml
