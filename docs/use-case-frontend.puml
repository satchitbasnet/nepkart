@startuml NEPKART-Frontend-UseCases
' Landscape format for presentations - export as PNG/SVG at plantuml.com
!theme plain
skinparam actorStyle awesome
skinparam useCase {
  BackgroundColor LightBlue
  BorderColor DarkBlue
}
skinparam pagesize 1600x900
skinparam defaultFontSize 11
' Force landscape: width > height, left-to-right layout
left to right direction

actor "Customer" as Customer
actor "Admin" as Admin

rectangle "NEPKART Frontend (React)" {
  ' Customer - consolidated
  usecase "Browse & Search Products" as UC1
  usecase "View Details" as UC2
  usecase "Manage Cart" as UC3
  usecase "Sign Up" as UC4
  usecase "Login / Logout" as UC5
  usecase "Forgot / Reset Password" as UC6
  usecase "Checkout" as UC7
  ' Admin
  usecase "Admin Login" as UC8
  usecase "Manage Inventory" as UC9
  usecase "View / Update Orders" as UC10
  usecase "View / Manage Customers" as UC11
}

Customer --> UC1
Customer --> UC2
Customer --> UC3
Customer --> UC4
Customer --> UC5
Customer --> UC6
Customer --> UC7

Admin --> UC8
Admin --> UC9
Admin --> UC10
Admin --> UC11
@enduml
